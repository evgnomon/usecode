#!/usr/bin/env python3
"""mkunit - Create a systemd unit file to run a command."""

import argparse
import os
import sys
from pathlib import Path


UNIT_TEMPLATE = """\
[Unit]
Description={description}
After=network.target

[Service]
Type=simple
ExecStart={exec_start}
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
"""


def main():
    parser = argparse.ArgumentParser(
        prog="mkunit",
        description="Create a systemd unit file to run a command.",
        usage="mkunit <unit-name> <command> [args...] [options]",
    )
    parser.add_argument("unit_name", help="Name of the systemd unit (without .service)")
    parser.add_argument("command", nargs=argparse.REMAINDER, help="Command to run")
    parser.add_argument(
        "--description",
        "-d",
        default=None,
        help="Unit description (defaults to 'Run: <command>')",
    )
    parser.add_argument(
        "--output",
        "-o",
        default=None,
        help="Output path (default: <unit-name>.service in current dir)",
    )
    parser.add_argument(
        "--install",
        "-i",
        action="store_true",
        help="Install to /etc/systemd/system/ (requires root)",
    )
    parser.add_argument(
        "--enable",
        "-e",
        action="store_true",
        help="Enable the unit after installing (implies --install)",
    )

    args = parser.parse_args()

    if not args.command:
        parser.error("You must provide a command to run.")

    # Strip leading '--' separator if present
    command = args.command
    if command and command[0] == "--":
        command = command[1:]

    exec_start = " ".join(command)
    description = args.description or f"Run: {exec_start}"
    unit_name = args.unit_name
    if not unit_name.endswith(".service"):
        unit_name_full = f"{unit_name}.service"
    else:
        unit_name_full = unit_name
        unit_name = unit_name[:-8]

    content = UNIT_TEMPLATE.format(
        description=description,
        exec_start=exec_start,
    )

    # Determine output path
    if args.enable:
        args.install = True

    if args.install:
        output_path = Path(f"/etc/systemd/system/{unit_name_full}")
    else:
        output_path = Path(args.output) if args.output else Path(f"{unit_name_full}")

    # Write the file
    try:
        output_path.write_text(content)
    except PermissionError:
        print(f"Error: Permission denied writing to {output_path}", file=sys.stderr)
        print(
            "Tip: Run with sudo, or omit --install to write locally.", file=sys.stderr
        )
        sys.exit(1)

    print(f"✓ Created: {output_path}")
    print(f"  Command: {exec_start}")

    if args.install:
        print("\nReloading systemd daemon...")
        ret = os.system("systemctl daemon-reload")
        if ret != 0:
            print("Warning: daemon-reload failed.", file=sys.stderr)
        else:
            print("✓ Daemon reloaded.")

        if args.enable:
            print(f"Enabling {unit_name_full}...")
            ret = os.system(f"systemctl enable {unit_name_full}")
            if ret == 0:
                print(f"✓ Enabled {unit_name_full}.")
            else:
                print(f"Warning: Failed to enable {unit_name_full}.", file=sys.stderr)

    else:
        print(f"\nTo install and start:")
        print(f"  sudo cp {output_path} /etc/systemd/system/")
        print(f"  sudo systemctl daemon-reload")
        print(f"  sudo systemctl enable --now {unit_name_full}")


if __name__ == "__main__":
    main()
