#!/usr/bin/env bash
set -euo pipefail

# Creates .github/workflows/yacht.yml with a valid Yacht workflow
# Fixed: delete event has NO branch filtering → use job if: condition instead

mkdir -p .github/workflows 2>/dev/null || true

cat > .github/workflows/yacht.yaml << 'EOF'
name: Yacht

on:
  workflow_dispatch:
  push:
    branches:
      - '*'
    tags:
      - '*'
  delete:
  # schedule:
  #   - cron: '0 3 * * *'

jobs:
  yacht:
    runs-on: ubuntu-latest
    if: >-
      (github.event_name == 'push') ||
      (github.event_name == 'workflow_dispatch') ||
      (github.event_name == 'delete' &&
       github.event.ref_type == 'branch' &&
       github.event.ref != 'main')
    container:
      image: ghcr.io/evgnomon/barge:main
    permissions:
      contents: read
      packages: write
    steps:
      - uses: actions/checkout@v4
      - name: Run Playbook
        uses: evgnomon/yacht@main
        with:
          vault: ${{ secrets.VAULT_FILE }}
          vault_pass: ${{ secrets.VAULT_PASS }}
          github_token: ${{ secrets.GITHUB_TOKEN }}
EOF

mkdir -p playbooks 2>/dev/null || true

if [ ! -f playbooks/main.yaml ]; then
  cat > playbooks/main.yaml << 'EOF'
- name: Build
  hosts: localhost
  gather_facts: false
  collections:
    - evgnomon.catamaran
  roles:
    - role: z_secrets
    - role: z_defaults
    - role: z_build

- name: Publish Galaxy Collection
  hosts: localhost
  gather_facts: false
  collections:
    - evgnomon.catamaran
  roles:
    - role: z_galaxy_col
EOF
fi

cat << 'EOF'
Enjoy smooth Yacht automation! 🛥️
EOF
