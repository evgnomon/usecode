#!/usr/bin/env bash
set -euo pipefail

ROOT="$HOME/src/github.com/$USER/usecode"
cd "$ROOT"
PLAT_HOME="${PLAT_HOME:-$HOME/.plat}"

usage() {
  echo "Usage: $0 [options] <service> <action> [action...]"
  echo "       $0 apply"
  echo ""
  echo "Options:"
  echo "  -t <tenant>      Tenant name (default: sys)"
  echo "  -n <namespace>   Namespace (default: main)"
  echo "  -p <pod>         Pod name (required)"
  echo ""
  echo "Actions: up, down, destroy, restart, logs, backup, restore, port, push, pull, undefine"
  echo ""
  echo "apply: converge this host to the desired state declared by env files under"
  echo "       \$PLAT_HOME (driven by STATUS=up|down)."
  echo ""
  echo "Examples:"
  echo "  $0 -p vault1 vaultwarden up"
  echo "  $0 -t acme -n prod -p vault1 vaultwarden up"
  echo "  $0 -t acme -n prod -p web1 caddy up"
  echo "  $0 apply"
  exit 1
}

# Set or replace KEY=VALUE in an env file (idempotent).
set_env_var() {
  local file="$1" key="$2" value="$3"
  if grep -q "^${key}=" "$file"; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$file"
  else
    echo "${key}=${value}" >> "$file"
  fi
}

# `apply`: walk env files and converge each to its desired STATUS.
# Every env under $PLAT_HOME belongs to this host by definition.
if [[ "${1:-}" == "apply" ]]; then
  if [[ ! -d "$PLAT_HOME" ]]; then
    echo "No PLAT_HOME at $PLAT_HOME"
    exit 0
  fi
  rc=0
  read_env_var() { awk -F= -v k="$2" '$1 == k { sub("^[^=]*=", ""); print; exit }' "$1"; }
  while IFS= read -r -d '' env_file; do
    env_status=$(read_env_var "$env_file" STATUS)
    env_tenant=$(read_env_var "$env_file" TENANT)
    env_namespace=$(read_env_var "$env_file" NAMESPACE)
    env_pod=$(read_env_var "$env_file" POD)
    env_service=$(basename "$env_file" .env)
    env_status="${env_status:-down}"
    if [[ "$env_status" != "up" && "$env_status" != "down" ]]; then
      echo "skip $env_file: STATUS=$env_status (expected up|down)"
      continue
    fi
    echo "==> $env_tenant/$env_namespace/$env_pod $env_service => $env_status"
    if ! "$0" -t "$env_tenant" -n "$env_namespace" -p "$env_pod" "$env_service" "$env_status"; then
      rc=1
      echo "!!  failed: $env_service ($env_status)"
    fi
  done < <(find "$PLAT_HOME" -mindepth 4 -maxdepth 4 -type f -name '*.env' -print0 | sort -z)
  exit "$rc"
fi

TENANT="sys"
NAMESPACE="main"
POD=""

while getopts "t:n:p:" opt; do
  case "$opt" in
    t) TENANT="$OPTARG" ;;
    n) NAMESPACE="$OPTARG" ;;
    p) POD="$OPTARG" ;;
    *) usage ;;
  esac
done
shift $((OPTIND - 1))

if [[ -z "$POD" || $# -lt 2 ]]; then
  usage
fi

SERVICE="$1"; shift

BLUEPRINT_DIR="$ROOT/lib/templates/lib/$SERVICE"
ENV_FILE="$PLAT_HOME/$TENANT/$NAMESPACE/$POD/$SERVICE.env"

if [[ ! -d "$BLUEPRINT_DIR" ]]; then
  echo "Error: no blueprint found at $BLUEPRINT_DIR"
  exit 1
fi

allocate_port() {
  local used_ports
  used_ports=$(grep -rh '^PORT=' "$PLAT_HOME" 2>/dev/null | cut -d= -f2 | sort -un)
  local port
  while true; do
    port=$((RANDOM % 55001 + 10000))
    if ! echo "$used_ports" | grep -qx "$port"; then
      echo "$port"
      return
    fi
  done
}

if [[ "$1" == "undefine" ]]; then
  if [[ -f "$ENV_FILE" ]]; then
    rm -f "$ENV_FILE"
    echo "Removed $ENV_FILE"
  else
    echo "No env file at $ENV_FILE"
  fi
  exit 0
fi

if [[ ! -f "$ENV_FILE" ]]; then
  mkdir -p "$(dirname "$ENV_FILE")"
  PORT=$(allocate_port)
  cat > "$ENV_FILE" <<EOF
TENANT=$TENANT
NAMESPACE=$NAMESPACE
POD=$POD
STATUS=down
PORT=$PORT
SUBDOMAIN=$POD
DOMAIN_SUFFIX=local.zygote.run
DOMAIN=$POD.$NAMESPACE.$TENANT.local.zygote.run
CADDY_POD=caddy-1
EOF
  echo "Created $ENV_FILE with defaults (STATUS=down, PORT=$PORT, SUBDOMAIN=$POD)."
  if [[ "${1:-}" != "up" ]]; then
    exit 0
  fi
fi

# Ensure PORT exists in older env files that predate auto-allocation.
if ! grep -q '^PORT=' "$ENV_FILE"; then
  PORT=$(allocate_port)
  echo "PORT=$PORT" >> "$ENV_FILE"
  echo "Assigned PORT=$PORT to $ENV_FILE"
fi

# Track desired state on the env file for `apply` to consume later.
case "${1:-}" in
  up|restart) set_env_var "$ENV_FILE" STATUS up ;;
  down|destroy) set_env_var "$ENV_FILE" STATUS down ;;
esac

# Load env, then derive DOMAIN only if the env file didn't set one (override-friendly).
set -a
source "$ENV_FILE"
set +a

if [[ -z "${DOMAIN:-}" && -n "${SUBDOMAIN:-}" ]]; then
  DOMAIN_SUFFIX="${DOMAIN_SUFFIX:-local.zygote.run}"
  DOMAIN="${SUBDOMAIN}.${NAMESPACE}.${TENANT}.${DOMAIN_SUFFIX}"
fi
export DOMAIN DOMAIN_SUFFIX

# Show all resolved port mappings from the compose file.
if [[ "$1" == "port" ]]; then
  COMPOSE_FILE="$BLUEPRINT_DIR/deploy/podman/podman-compose.yaml"
  if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Error: no compose file at $COMPOSE_FILE"
    exit 1
  fi
  set -a
  source "$ENV_FILE"
  set +a
  envsubst < "$COMPOSE_FILE" | grep -oP '"\K\d+\.\d+\.\d+\.\d+:\d+:\d+"' | sed 's/"$//' || true
  exit 0
fi

export ENV_FILE
exec "$BLUEPRINT_DIR/scripts/plat" "$@"
