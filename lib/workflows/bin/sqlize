#!/usr/bin/env python3
"""
SQL Migration Runner

Applies SQL migration files from a directory in alphabetical order.
Supports both 'up' (apply) and 'down' (rollback) migrations.
"""

import argparse
import os
import sys
from pathlib import Path

try:
    import psycopg2
except ImportError:
    psycopg2 = None

try:
    import sqlite3
except ImportError:
    sqlite3 = None


def get_migration_files(directory: str, direction: str = "up") -> list[Path]:
    """
    Get all SQL migration files from directory, filtered by direction and sorted alphabetically.

    Args:
        directory: Path to migrations directory
        direction: 'up' for applying migrations, 'down' for rollback

    Returns:
        Sorted list of migration file paths
    """
    migrations_path = Path(directory)

    if not migrations_path.exists():
        print(f"Error: Directory '{directory}' does not exist")
        sys.exit(1)

    if not migrations_path.is_dir():
        print(f"Error: '{directory}' is not a directory")
        sys.exit(1)

    pattern = f"*_{direction}.sql"
    files = list(migrations_path.glob(pattern))

    if direction == "down":
        return sorted(files, reverse=True)
    return sorted(files)


def read_migration(file_path: Path) -> str:
    """Read SQL content from migration file."""
    with open(file_path, "r", encoding="utf-8") as f:
        return f.read()


def apply_migrations_sqlite(
    db_path: str, migrations: list[Path], dry_run: bool = False
) -> None:
    """Apply migrations using SQLite."""
    if sqlite3 is None:
        print("Error: sqlite3 module not available")
        sys.exit(1)

    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()

    try:
        for migration_file in migrations:
            sql = read_migration(migration_file)
            print(f"{'[DRY RUN] ' if dry_run else ''}Applying: {migration_file.name}")

            if not dry_run:
                cursor.executescript(sql)
                conn.commit()

            print(f"  ✓ Success")
    except Exception as e:
        conn.rollback()
        print(f"  ✗ Error: {e}")
        sys.exit(1)
    finally:
        conn.close()


def apply_migrations_postgres(
    host: str,
    port: int,
    database: str,
    user: str,
    password: str,
    migrations: list[Path],
    dry_run: bool = False,
) -> None:
    """Apply migrations using PostgreSQL."""
    if psycopg2 is None:
        print(
            "Error: psycopg2 module not installed. Install with: pip install psycopg2-binary"
        )
        sys.exit(1)

    conn = psycopg2.connect(
        host=host, port=port, database=database, user=user, password=password
    )
    conn.autocommit = False
    cursor = conn.cursor()

    try:
        for migration_file in migrations:
            sql = read_migration(migration_file)
            print(f"{'[DRY RUN] ' if dry_run else ''}Applying: {migration_file.name}")

            if not dry_run:
                cursor.execute(sql)
                conn.commit()

            print(f"  ✓ Success")
    except Exception as e:
        conn.rollback()
        print(f"  ✗ Error: {e}")
        sys.exit(1)
    finally:
        cursor.close()
        conn.close()


def apply_migrations_print_only(migrations: list[Path]) -> None:
    """Print migrations without executing (for preview or manual execution)."""
    print("\n" + "=" * 60)
    print("MIGRATION FILES (in execution order)")
    print("=" * 60 + "\n")

    for i, migration_file in enumerate(migrations, 1):
        print(f"{i}. {migration_file.name}")
        print("-" * 40)
        sql = read_migration(migration_file)
        print(sql)
        print()


def main():
    parser = argparse.ArgumentParser(
        description="Apply SQL migrations from a directory in alphabetical order",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # List migrations without executing
  %(prog)s ./db/templates --print-only

  # Apply 'up' migrations to SQLite database
  %(prog)s ./db/templates --sqlite ./database.db

  # Apply 'down' migrations (rollback) to SQLite
  %(prog)s ./db/templates --sqlite ./database.db --direction down

  # Apply to PostgreSQL
  %(prog)s ./db/templates --postgres --host localhost --database mydb --user admin --password secret

  # Dry run (show what would be executed)
  %(prog)s ./db/templates --sqlite ./database.db --dry-run
        """,
    )

    parser.add_argument("directory", help="Directory containing SQL migration files")

    parser.add_argument(
        "--direction",
        choices=["up", "down"],
        default="up",
        help="Migration direction: 'up' to apply, 'down' to rollback (default: up)",
    )

    parser.add_argument(
        "--print-only",
        action="store_true",
        help="Print migration files and their content without executing",
    )

    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be executed without making changes",
    )

    # SQLite options
    parser.add_argument(
        "--sqlite", metavar="DB_PATH", help="Path to SQLite database file"
    )

    # PostgreSQL options
    parser.add_argument(
        "--postgres", action="store_true", help="Use PostgreSQL database"
    )

    parser.add_argument(
        "--host", default="localhost", help="PostgreSQL host (default: localhost)"
    )
    parser.add_argument(
        "--port", type=int, default=5432, help="PostgreSQL port (default: 5432)"
    )
    parser.add_argument("--database", help="PostgreSQL database name")
    parser.add_argument("--user", help="PostgreSQL username")
    parser.add_argument("--password", default="", help="PostgreSQL password")

    args = parser.parse_args()

    # Get migration files
    migrations = get_migration_files(args.directory, args.direction)

    if not migrations:
        print(f"No *_{args.direction}.sql files found in '{args.directory}'")
        sys.exit(0)

    print(f"Found {len(migrations)} migration(s) ({args.direction})")

    # Execute based on mode
    if args.print_only:
        apply_migrations_print_only(migrations)
    elif args.sqlite:
        apply_migrations_sqlite(args.sqlite, migrations, args.dry_run)
    elif args.postgres:
        if not args.database or not args.user:
            print("Error: --database and --user are required for PostgreSQL")
            sys.exit(1)
        apply_migrations_postgres(
            args.host,
            args.port,
            args.database,
            args.user,
            args.password,
            migrations,
            args.dry_run,
        )
    else:
        print(
            "No database specified. Use --print-only to preview, --sqlite, or --postgres"
        )
        parser.print_help()
        sys.exit(1)

    print("\nDone!")


if __name__ == "__main__":
    main()
