#!/usr/bin/env python3
import os
import json
import click
import yaml
import psycopg2
from psycopg2.extras import Json
from pathlib import Path
from dotenv import load_dotenv

load_dotenv()


def find_pg_config():
    """Search for .pg.json starting from cwd and walking up to /."""
    d = os.path.abspath(os.getcwd())
    while True:
        candidate = os.path.join(d, ".pg.json")
        if os.path.isfile(candidate):
            with open(candidate, "r") as f:
                return json.load(f)
        parent = os.path.dirname(d)
        if parent == d:
            break
        d = parent
    return {}


_pg_config = find_pg_config()

PG_PASSWORD = _pg_config.get("password", "t6drtfyig7")
PG_USER = _pg_config.get("user", "admin")
PG_PORT = _pg_config.get("port", 5432)
PG_HOST = _pg_config.get("host", "localhost")
PG_DATABASE = _pg_config.get("database", "postgres")


def build_dsn():
    return f"host={PG_HOST} port={PG_PORT} dbname={PG_DATABASE} user={PG_USER} password={PG_PASSWORD}"


def find_yaml_files(directory):
    for root, _, files in os.walk(directory):
        for file in files:
            if file.endswith(".yaml") or file.endswith(".yml"):
                yield os.path.join(root, file)


def parse_resource(doc):
    api_version = doc.get("apiVersion")
    kind = doc.get("kind")
    metadata = doc.get("metadata", {})
    name = metadata.get("name")
    if not api_version or not kind or not name:
        return None
    return {
        "api_version": api_version,
        "kind": kind,
        "name": name,
        "namespace": metadata.get("namespace", "main"),
        "labels": metadata.get("labels"),
        "annotations": metadata.get("annotations"),
        "spec": doc.get("spec", {}),
    }


def upsert_resource(cursor, resource, tenant):
    cursor.execute(
        """
        INSERT INTO public.resources
            (api_version, kind, name, namespace, tenant, labels, annotations, spec)
        VALUES (%s, %s, %s, %s, %s, %s, %s, %s)
        ON CONFLICT (api_version, kind, name, namespace, tenant) DO UPDATE SET
            labels      = EXCLUDED.labels,
            annotations = EXCLUDED.annotations,
            spec        = EXCLUDED.spec
        """,
        (
            resource["api_version"],
            resource["kind"],
            resource["name"],
            resource["namespace"],
            tenant,
            Json(resource["labels"]) if resource["labels"] is not None else None,
            Json(resource["annotations"])
            if resource["annotations"] is not None
            else None,
            Json(resource["spec"]),
        ),
    )


def resource_to_doc(row):
    api_version, kind, name, namespace, labels, annotations, spec = row
    metadata = {"name": name, "namespace": namespace}
    if labels:
        metadata["labels"] = labels
    if annotations:
        metadata["annotations"] = annotations
    doc = {"apiVersion": api_version, "kind": kind, "metadata": metadata}
    if spec:
        doc["spec"] = spec
    return doc


@click.group()
def cli():
    """ysyc - sync resource YAMLs with PostgreSQL."""


@cli.command()
@click.argument(
    "directory", type=click.Path(exists=True, file_okay=False, dir_okay=True)
)
@click.option(
    "--tenant",
    default="system",
    show_default=True,
    help="Tenant value written to every row",
)
@click.option(
    "--dry-run",
    is_flag=True,
    help="Parse files and print resources without writing to the database",
)
def sync(directory, tenant, dry_run):
    """Sync Kubernetes resource YAMLs from DIRECTORY into PostgreSQL."""
    resources = []

    for path in find_yaml_files(directory):
        try:
            with open(path) as f:
                docs = yaml.safe_load_all(f)
                for doc in docs:
                    if not isinstance(doc, dict):
                        continue
                    resource = parse_resource(doc)
                    if resource:
                        resources.append((path, resource))
                    else:
                        click.echo(
                            f"skip: missing apiVersion/kind/name in {path}", err=True
                        )
        except Exception as exc:
            click.echo(f"error reading {path}: {exc}", err=True)

    click.echo(f"found {len(resources)} resource(s)")

    if dry_run:
        for path, r in resources:
            click.echo(
                f"  {r['api_version']}/{r['kind']}  {r['namespace']}/{r['name']}  ({path})"
            )
        return

    conn = psycopg2.connect(build_dsn())
    try:
        with conn:
            with conn.cursor() as cur:
                for path, resource in resources:
                    upsert_resource(cur, resource, tenant)
                    click.echo(
                        f"  upserted {resource['api_version']}/{resource['kind']} {resource['namespace']}/{resource['name']}"
                    )
        click.echo("done.")
    finally:
        conn.close()


@cli.command()
@click.argument("directory", type=click.Path(file_okay=False, dir_okay=True))
@click.option(
    "--tenant",
    default="system",
    show_default=True,
    help="Tenant to filter resources by",
)
@click.option(
    "--namespace",
    default=None,
    help="Filter by namespace (default: all namespaces)",
)
def dump(directory, tenant, namespace):
    """Dump all resources from PostgreSQL into YAML files under DIRECTORY.

    Each resource is written to DIRECTORY/<tenant>/<namespace>/<kind>/<name>.yaml.
    """
    out_dir = Path(directory)

    conn = psycopg2.connect(build_dsn())
    try:
        with conn.cursor() as cur:
            if namespace:
                cur.execute(
                    """
                    SELECT api_version, kind, name, namespace, labels, annotations, spec
                    FROM public.resources
                    WHERE tenant = %s AND namespace = %s
                    ORDER BY namespace, kind, name
                    """,
                    (tenant, namespace),
                )
            else:
                cur.execute(
                    """
                    SELECT api_version, kind, name, namespace, labels, annotations, spec
                    FROM public.resources
                    WHERE tenant = %s
                    ORDER BY namespace, kind, name
                    """,
                    (tenant,),
                )
            rows = cur.fetchall()
    finally:
        conn.close()

    click.echo(f"dumping {len(rows)} resource(s) to {out_dir}")

    for row in rows:
        _, kind, name, ns, _, _, _ = row
        dest = (
            out_dir
            / tenant.lower()
            / ns.lower()
            / kind.lower()
            / f"{name.lower()}.yaml"
        )
        dest.parent.mkdir(parents=True, exist_ok=True)
        doc = resource_to_doc(row)
        with open(dest, "w") as f:
            yaml.dump(doc, f, default_flow_style=False, allow_unicode=True)
        click.echo(f"  wrote {dest}")

    click.echo("done.")


if __name__ == "__main__":
    cli()
