#!/usr/bin/env bash
#
# mkdeb - Package files into a Debian (.deb) package
#
# Usage: mkdeb [OPTIONS]
#
# Options:
#   -n, --name NAME           Package name (default: from .deb.json or directory name)
#   -v, --version VERSION     Package version (default: from .deb.json or "0.1.0")
#   -d, --description DESC    Package description
#   -m, --maintainer EMAIL    Maintainer email (default: "maintainer@example.com")
#   -a, --arch ARCH           Target architecture (default: auto-detect)
#   -o, --output DIR          Output directory for .deb file (default: ./dist)
#   -p, --prefix PREFIX       Installation prefix for docs (default: /usr)
#   -s, --source DIR          Source directory (default: .)
#   --depends DEPS            Comma-separated list of dependencies
#   --section SECTION         Package section (default: utils)
#   --priority PRIORITY       Package priority (default: optional)
#   --homepage URL            Project homepage URL
#   --license LICENSE         License (default: MIT)
#   -h, --help                Show this help message
#
# .deb.json / .deb.jsonc:
#   Place a .deb.json or .deb.jsonc file in the source directory to set
#   package properties:
#   { "name": "myapp", "version": "1.0.0", "description": "My app",
#     "maintainer": "user@example.com", "depends": "libc6",
#     "section": "utils", "priority": "optional",
#     "homepage": "https://example.com", "license": "MIT",
#     "root": "./pkg-root" }
#   .deb.jsonc may contain comments (stripped via /usr/local/bin/jsonc).
#   CLI arguments override values from these files.
#   "root" specifies a directory whose contents are copied into the package
#   root. E.g. if root is "./pkg-root" and it contains
#   usr/bin/myapp, the .deb will install /usr/bin/myapp.
#

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default values
PKG_NAME=""
PKG_VERSION=""
PKG_DESCRIPTION=""
PKG_MAINTAINER="maintainer@example.com"
PKG_ARCH=""
OUTPUT_DIR="./dist"
INSTALL_PREFIX="/usr"
SOURCE_DIR="."
PKG_DEPENDS=""
PKG_SECTION="utils"
PKG_PRIORITY="optional"
PKG_HOMEPAGE=""
PKG_LICENSE="HGL"
PKG_ROOT=""

# Helper functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

die() {
    log_error "$1"
    exit 1
}

show_help() {
    head -38 "$0" | tail -36 | sed 's/^# \?//'
    exit 0
}

# Parse .deb.json or .deb.jsonc for package properties
parse_deb_json() {
    local json_file="$1"

    if [[ ! -f "$json_file" ]]; then
        return
    fi

    if ! command -v jq &>/dev/null; then
        die "jq is required to parse $json_file. Please install jq."
    fi

    log_info "Reading package properties from $json_file"

    # For .jsonc we strip comments via /usr/local/bin/jsonc before handing to jq.
    local content
    if [[ "$json_file" == *.jsonc ]]; then
        if [[ ! -x /usr/local/bin/jsonc ]]; then
            die "/usr/local/bin/jsonc is required to parse $json_file."
        fi
        content=$(/usr/local/bin/jsonc < "$json_file")
    else
        content=$(cat "$json_file")
    fi

    local val
    val=$(jq -r '.name // empty' <<<"$content") && [[ -z "$PKG_NAME" && -n "$val" ]] && PKG_NAME="$val"
    val=$(jq -r '.version // empty' <<<"$content") && [[ -z "$PKG_VERSION" && -n "$val" ]] && PKG_VERSION="$val"
    val=$(jq -r '.description // empty' <<<"$content") && [[ -n "$val" ]] && PKG_DESCRIPTION="$val"
    val=$(jq -r '.maintainer // empty' <<<"$content") && [[ -n "$val" ]] && PKG_MAINTAINER="$val"
    val=$(jq -r '.arch // empty' <<<"$content") && [[ -z "$PKG_ARCH" && -n "$val" ]] && PKG_ARCH="$val"
    val=$(jq -r '.depends // empty' <<<"$content") && [[ -n "$val" ]] && PKG_DEPENDS="$val"
    val=$(jq -r '.section // empty' <<<"$content") && [[ -n "$val" ]] && PKG_SECTION="$val"
    val=$(jq -r '.priority // empty' <<<"$content") && [[ -n "$val" ]] && PKG_PRIORITY="$val"
    val=$(jq -r '.homepage // empty' <<<"$content") && [[ -n "$val" ]] && PKG_HOMEPAGE="$val"
    val=$(jq -r '.license // empty' <<<"$content") && [[ -n "$val" ]] && PKG_LICENSE="$val"
    val=$(jq -r '.root // empty' <<<"$content") || true
    if [[ -z "$PKG_ROOT" && -n "$val" ]]; then
      PKG_ROOT="$val"
    fi
}

# Detect system architecture and map to Debian arch
detect_arch() {
    local machine
    machine=$(uname -m)

    case "$machine" in
        x86_64)  echo "amd64" ;;
        aarch64) echo "arm64" ;;
        armv7l)  echo "armhf" ;;
        i686)    echo "i386" ;;
        *)       echo "$machine" ;;
    esac
}

# Parse command line arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n|--name)
                PKG_NAME="$2"
                shift 2
                ;;
            -v|--version)
                PKG_VERSION="$2"
                shift 2
                ;;
            -d|--description)
                PKG_DESCRIPTION="$2"
                shift 2
                ;;
            -m|--maintainer)
                PKG_MAINTAINER="$2"
                shift 2
                ;;
            -a|--arch)
                PKG_ARCH="$2"
                shift 2
                ;;
            -o|--output)
                OUTPUT_DIR="$2"
                shift 2
                ;;
            -p|--prefix)
                INSTALL_PREFIX="$2"
                shift 2
                ;;
            -s|--source)
                SOURCE_DIR="$2"
                shift 2
                ;;
            --depends)
                PKG_DEPENDS="$2"
                shift 2
                ;;
            --section)
                PKG_SECTION="$2"
                shift 2
                ;;
            --priority)
                PKG_PRIORITY="$2"
                shift 2
                ;;
            --homepage)
                PKG_HOMEPAGE="$2"
                shift 2
                ;;
            --license)
                PKG_LICENSE="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                ;;
            *)
                die "Unknown option: $1"
                ;;
        esac
    done
}

# Validate requirements
check_requirements() {
    log_info "Checking requirements..."

    if ! command -v dpkg-deb &>/dev/null; then
        die "dpkg-deb not found. Please install dpkg."
    fi
}

# Create the DEBIAN control file
create_control() {
    local debian_dir="$1/DEBIAN"

    mkdir -p "$debian_dir"

    # Calculate installed size (in KB)
    local installed_size
    installed_size=$(du -sk "$1" | cut -f1)

    log_info "Creating DEBIAN/control..."

    cat > "$debian_dir/control" << EOF
Package: $PKG_NAME
Version: $PKG_VERSION
Section: $PKG_SECTION
Priority: $PKG_PRIORITY
Architecture: $PKG_ARCH
Maintainer: $PKG_MAINTAINER
Installed-Size: $installed_size
Description: $PKG_DESCRIPTION
EOF

    # Add optional fields
    if [[ -n "$PKG_DEPENDS" ]]; then
        echo "Depends: $PKG_DEPENDS" >> "$debian_dir/control"
    fi

    if [[ -n "$PKG_HOMEPAGE" ]]; then
        echo "Homepage: $PKG_HOMEPAGE" >> "$debian_dir/control"
    fi
}

# Create post-install script (optional)
create_postinst() {
    local debian_dir="$1/DEBIAN"

    cat > "$debian_dir/postinst" << 'EOF'
#!/bin/sh
set -e

# Update shared library cache if needed
if [ -d /usr/lib ] && command -v ldconfig >/dev/null 2>&1; then
    ldconfig
fi

exit 0
EOF

    chmod 755 "$debian_dir/postinst"
}

# Create copyright file
create_copyright() {
    local doc_dir="$1$INSTALL_PREFIX/share/doc/$PKG_NAME"

    mkdir -p "$doc_dir"

    # Find license file by walking up parent directories
    local license_text=""
    local license_file=""
    local search_dir
    search_dir=$(cd "$SOURCE_DIR" && pwd)
    while [[ -n "$search_dir" ]]; do
        if [[ -f "$search_dir/COPYING" ]]; then
            license_file="$search_dir/COPYING"
            break
        elif [[ -f "$search_dir/LICENSE" ]]; then
            license_file="$search_dir/LICENSE"
            break
        fi
        [[ "$search_dir" == "/" ]] && break
        search_dir=$(dirname "$search_dir")
    done

    if [[ -n "$license_file" ]]; then
        log_info "Using license file: $license_file"
        license_text=$(cat "$license_file")
    else
        echo "No COPYING or LICENSE file found"
    fi

    # Format license text for Debian copyright format (indent lines, replace blank lines with " .")
    local formatted_license=""
    if [[ -n "$license_text" ]]; then
        formatted_license=$(echo "$license_text" | sed 's/^$/ ./; s/^/ /')
    fi

    cat > "$doc_dir/copyright" << EOF
Format: https://www.debian.org/doc/packaging-manuals/copyright-format/1.0/
Upstream-Name: $PKG_NAME
Files: *
Copyright: $(date +%Y) $PKG_MAINTAINER
License: $PKG_LICENSE

License: $PKG_LICENSE
$formatted_license
EOF
}

# Build the .deb package
build_deb() {
    local build_dir="$1"
    local deb_file="$OUTPUT_DIR/${PKG_NAME}_${PKG_VERSION}_${PKG_ARCH}.deb"

    log_info "Building .deb package..."

    # Set proper permissions
    find "$build_dir" -type d -exec chmod 755 {} \;
    find "$build_dir$INSTALL_PREFIX" -type f -exec chmod 644 {} \; 2>/dev/null || true
    find "$build_dir$INSTALL_PREFIX/bin" -type f -exec chmod 755 {} \; 2>/dev/null || true
    find "$build_dir$INSTALL_PREFIX/lib" -name "*.so*" -exec chmod 755 {} \; 2>/dev/null || true

    # Build the package
    dpkg-deb --build --root-owner-group "$build_dir" "$deb_file"

    log_success "Package created: $deb_file"

    # Show package info
    echo ""
    log_info "Package information:"
    dpkg-deb --info "$deb_file"

    echo ""
    log_info "Package contents:"
    dpkg-deb --contents "$deb_file"

    tree $build_dir

}

# Copy root directory contents into build root
install_root_hierarchy() {
    local build_dir="$1"

    if [[ -z "$PKG_ROOT" ]]; then
        return
    fi

    local root_dir="$SOURCE_DIR/$PKG_ROOT"

    if [[ ! -d "$root_dir" ]]; then
        die "Root directory not found: $root_dir"
    fi

    log_info "Installing root hierarchy from $root_dir/"
    cp -rL "$root_dir/." "$build_dir/"
}

# Main function
main() {
    parse_args "$@"

    # Read properties from .deb.jsonc / .deb.json (CLI args take precedence).
    # Prefer .deb.jsonc when both exist.
    if [[ -f "$SOURCE_DIR/.deb.jsonc" ]]; then
        parse_deb_json "$SOURCE_DIR/.deb.jsonc"
    else
        parse_deb_json "$SOURCE_DIR/.deb.json"
    fi

    # Set defaults if still not set
    if [[ -z "$PKG_NAME" ]]; then
        PKG_NAME=$(basename "$(cd "$SOURCE_DIR" && pwd)")
    fi

    if [[ -z "$PKG_VERSION" ]]; then
        PKG_VERSION="0.1.0"
    fi

    if [[ -z "$PKG_ARCH" ]]; then
        PKG_ARCH=$(detect_arch)
    fi

    # Sanitize package name (lowercase, replace underscores)
    PKG_NAME=$(echo "$PKG_NAME" | tr '[:upper:]' '[:lower:]' | tr '_' '-')

    echo ""
    echo "========================================"
    echo "  Debian Package Builder"
    echo "========================================"
    echo ""
    log_info "Package: $PKG_NAME"
    log_info "Version: $PKG_VERSION"
    log_info "Architecture: $PKG_ARCH"
    log_info "Description: $PKG_DESCRIPTION"
    echo ""

    check_requirements

    # Create build directory
    local build_dir
    build_dir=$(mktemp -d)
    # trap "rm -rf '$build_dir'" EXIT

    # Create Output Directory

    rm $OUTPUT_DIR/*.deb 2>/dev/null || true
    mkdir -p "$OUTPUT_DIR"

    # Copy root directory hierarchy into package root
    install_root_hierarchy "$build_dir"

    # Create Debian package structure
    create_control "$build_dir"
    create_postinst "$build_dir"
    create_copyright "$build_dir"

    # Build the .deb
    build_deb "$build_dir"

    echo ""
    log_success "Done! Install with: sudo dpkg -i $OUTPUT_DIR/${PKG_NAME}_${PKG_VERSION}_${PKG_ARCH}.deb"
}

main "$@"
